   "source": [
    "predictions = model.predict(X_val)\n",
    "ret_mean, ret_std = scaler.mean_[-2], scaler.scale_[-2]\n",
    "pred_returns = (predictions * ret_std) + ret_mean\n",
    "last_price = df['Close'].iloc[-1]\n",
    "\n",
    "print(\"\\n--- FORWARD PROJECTION ---\")\n",
    "for i in range(5):\n",
    "    p = last_price * np.exp(pred_returns[-1, i])\n",
    "    print(f\"T+{i+1}m: {p:.2f} ({'UP' if pred_returns[-1, i] > 0 else 'DOWN'})\")\n",
    "    last_price = p"
