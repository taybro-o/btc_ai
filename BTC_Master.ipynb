  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# BTC AI Master Notebook\n",
    "This notebook consolidates data downloading, exploratory analysis, and feature engineering (technical indicators) into a single workflow."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Data Acquisition & Updates\n",
    "Uses `kagglehub` to download the latest Bitcoin historical data and merge it with our local master file."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "import kagglehub\n",
    "import os\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from datetime import datetime\n",
    "\n",
    "# Configuration\n",
    "DATASET_SLUG = \"mczielinski/bitcoin-historical-data\"\n",
    "DATA_DIR = \"data\"\n",
    "MASTER_FILE = os.path.join(DATA_DIR, \"btcusdt_analysis_data.csv\")\n",
    "\n",
    "def download_and_update_data():\n",
    "    print(f\"Downloading dataset from Kaggle...\")\n",
    "    path = kagglehub.dataset_download(DATASET_SLUG)\n",
    "    \n",
    "    # Find the CSV file\n",
    "    csv_file = None\n",
    "    for root, dirs, filenames in os.walk(path):\n",
    "        for filename in filenames:\n",
    "            if filename.endswith(\".csv\"):\n",
    "                csv_file = os.path.join(root, filename)\n",
    "                break\n",
    "    \n",
    "    if not csv_file:\n",
    "        print(\"Error: No CSV found.\")\n",
    "        return\n",
    "\n",
    "    new_df = pd.read_csv(csv_file)\n",
    "    \n",
    "    if os.path.exists(MASTER_FILE):\n",
    "        print(\"Merging with existing data...\")\n",
    "        master_df = pd.read_csv(MASTER_FILE)\n",
    "        combined_df = pd.concat([master_df, new_df]).drop_duplicates(subset=['Timestamp'], keep='last')\n",
    "        combined_df = combined_df.sort_values(by='Timestamp')\n",
    "    else:\n",
    "        print(\"Creating new master file...\")\n",
    "        combined_df = new_df.sort_values(by='Timestamp')\n",
    "\n",
    "    if not os.path.exists(DATA_DIR): os.makedirs(DATA_DIR)\n",
    "    combined_df.to_csv(MASTER_FILE, index=False)\n",
    "    print(f\"Success! Total rows: {len(combined_df)}\")\n",
    "\n",
    "# Run the update\n",
    "download_and_update_data()"
   ],
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Load and Preprocess\n",
    "Loading the master CSV and preparing the index."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "df = pd.read_csv(MASTER_FILE)\n",
    "df['Datetime'] = pd.to_datetime(df['Timestamp'], unit='s')\n",
    "df.set_index('Datetime', inplace=True)\n",
    "df.sort_index(inplace=True)\n",
    "print(\"DataFrame loaded with index. Sample:\")\n",
    "print(df.head())"
   ],
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Exploratory Data Analysis\n",
    "Visualizing the price trends and statistics."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "print(\"Basic Statistics:\")\n",
    "display(df.describe())\n",
    "\n",
    "# Price Plot\n",
    "plt.figure(figsize=(14, 6))\n",
    "plt.plot(df['Close'], label='BTC Price', color='blue', linewidth=0.5)\n",
    "plt.title('Bitcoin Historical Price (Full Dataset)')\n",
    "plt.grid(True)\n",
    "plt.show()\n",
    "\n",
    "# Volume vs Price (2021 Zoom)\n",
    "df_2021 = df[df.index.year == 2021]\n",
    "fig, ax1 = plt.subplots(figsize=(14, 6))\n",
    "ax1.plot(df_2021['Close'], color='blue', label='Price')\n",
    "ax2 = ax1.twinx()\n",
    "ax2.bar(df_2021.index, df_2021['Volume'], color='orange', alpha=0.3, label='Volume')\n",
    "plt.title('2021 Price vs Volume')\n",
    "plt.show()"
   ],
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Technical Indicators (Feature Engineering)\n",
    "Adding RSI, MACD, ADX, and more to the same DataFrame using vectorized operations."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "def apply_indicators(df):\n",
    "    # EMA Filters\n",
    "    df['EMA_20'] = df['Close'].ewm(span=20, adjust=False).mean()\n",
    "    df['EMA_50'] = df['Close'].ewm(span=50, adjust=False).mean()\n",
    "    df['EMA_200'] = df['Close'].ewm(span=200, adjust=False).mean()\n",
    "\n",
    "    # RSI\n",
    "    delta = df['Close'].diff()\n",
    "    gain = (delta.where(delta > 0, 0)).rolling(window=14).mean()\n",
    "    loss = (-delta.where(delta < 0, 0)).rolling(window=14).mean()\n",
    "    df['RSI'] = 100 - (100 / (1 + (gain / loss)))\n",
    "    \n",
    "    # Stochastic RSI\n",
    "    df['StochRSI'] = (df['RSI'] - df['RSI'].rolling(14).min()) / (df['RSI'].rolling(14).max() - df['RSI'].rolling(14).min())\n",
    "    \n",
    "    # MACD\n",
    "    df['MACD'] = df['Close'].ewm(span=12, adjust=False).mean() - df['Close'].ewm(span=26, adjust=False).mean()\n",
    "    df['MACD_Signal'] = df['MACD'].ewm(span=9, adjust=False).mean()\n",
    "    \n",
    "    # ADX (Simplified True Range implementation)\n",
    "    tr = pd.concat([df['High']-df['Low'], \n",
    "                    abs(df['High']-df['Close'].shift(1)), \n",
    "                    abs(df['Low']-df['Close'].shift(1))], axis=1).max(axis=1)\n",
    "    atr = tr.rolling(14).mean()\n",
    "    plus_dm = (df['High'].diff()).clip(lower=0)\n",
    "    minus_dm = (df['Low'].diff() * -1).clip(lower=0)\n",
    "    plus_di = 100 * (plus_dm.rolling(14).mean() / atr)\n",
    "    minus_di = 100 * (minus_dm.rolling(14).mean() / atr)\n",
    "    df['ADX'] = 100 * (abs(plus_di - minus_di) / (plus_di + minus_di)).rolling(14).mean()\n",
    "    \n",
    "    df.dropna(inplace=True)\n",
    "    return df\n",
    "\n",
    "df = apply_indicators(df)\n",
    "print(\"All indicators applied to the main DataFrame.\")\n",
    "print(f\"Final Feature Count: {df.shape[1]}\")\n",
    "print(df.tail())"
   ],
   "outputs": []
  }\n",
 ],
