  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Data Preparation for PatchTST\n",
    "Scaling data and creating overlapping sequences."
   ],
   "id": "4c48975efe6cd503"
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-04-14T15:47:23.026420Z",
     "start_time": "2026-04-14T15:47:22.851792Z"
    }
   },
   "source": [
    "from sklearn.preprocessing import StandardScaler\n",
    "\n",
    "LOOKBACK = 96  # 96 minutes input\n",
    "FORECAST = 5   # 5 minutes prediction\n",
    "\n",
    "features = ['Open', 'High', 'Low', 'Close', 'Volume', 'EMA_50', 'RSI', 'MACD', 'ADX', 'log_return']\n",
    "scaler = StandardScaler()\n",
    "scaled_data = scaler.fit_transform(df[features])\n",
    "\n",
    "def create_sequences(data, lookback, forecast):\n",
    "    X, y = [], []\n",
    "    for i in range(len(data) - lookback - forecast + 1):\n",
    "        X.append(data[i : i + lookback])\n",
    "        # Predict the next 5 LOG RETURNS (last column)\n",
    "        y.append(data[i + lookback : i + lookback + forecast, -1]) \n",
    "    return np.array(X), np.array(y)\n",
    "\n",
    "X, y = create_sequences(scaled_data, LOOKBACK, FORECAST)\n",
    "\n",
    "# Split: 90% Train, 10% Val\n",
    "split = int(len(X) * 0.9)\n",
    "X_train, X_val = X[:split], X[split:]\n",
    "y_train, y_val = y[:split], y[split:]\n",
    "print(f\"X_train shape: {X_train.shape}\")"
   ],
   "id": "e325c9784bb2119b",
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
